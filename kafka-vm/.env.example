# 클러스터 공통 (3개 VM 모두 동일한 값)
# 생성: docker run --rm confluentinc/cp-kafka:7.5.0 kafka-storage random-uuid
KAFKA_CLUSTER_ID=

# 이 VM의 브로커 ID (kafka-1=1, kafka-2=2, kafka-3=3)
BROKER_ID=1

# 각 VM의 GCP 내부 IP
KAFKA_HOST=10.0.0.x        # 이 VM의 IP
KAFKA_1_HOST=10.0.0.x      # kafka-1 내부 IP
KAFKA_2_HOST=10.0.0.x      # kafka-2 내부 IP
KAFKA_3_HOST=10.0.0.x      # kafka-3 내부 IP